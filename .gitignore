# Dependencies
node_modules

# Brainstorm session files
.superpowers/

# Build outputs
dist
build
.next

# Environment
.env
.env.local
.env.*.local

# Turbo
.turbo

# Misc
*.tsbuildinfo
.DS_Store

# Python
.venv/
__pycache__/

# OCR tool — screenshots are large binary assets, not source code
tools/game_ocr/ScreenShots/

# Playwright MCP cache
.playwright-mcp/

# Claude session state (settings.json IS tracked; only the lock file is ephemeral)
.claude/scheduled_tasks.lock

# Historical extractor outputs — regenerable, multi-GB, never belong in git
tools/historical_import/output_*/

# Stray pip stdout files (e.g. accidental "pip install x>=1.3" → file named =1.3)
/=*

# Debug HTML scrapes from local development
/roster-main-*.html

# Debug screenshots and snapshot dumps at repo root (Playwright/Chrome DevTools output)
/*.png
/*.txt

# Accidental browser-download duplicates ("foo (1).ext", "foo (2).ext")
* (1).*
* (2).*

# Design system hand-off zips (extracted to docs/design/boogeymen-system/ as needed)
*.zip

# Staged design system reference (source-of-truth lives in apps/web; this is local working copy)
docs/design/boogeymen-system/

# Research artifacts — large captures not suited for git
research/**/*.har
research/**/*_files/
research/Previous_NHL_Stats/

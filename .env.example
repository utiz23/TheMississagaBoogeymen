# ---------------------------------------------------------------
# Copy this file to .env and fill in values before running.
# ---------------------------------------------------------------

# Database — local dev (connecting from host machine to Docker container)
DATABASE_URL=postgresql://eanhl:changeme@localhost:5432/eanhl

# Database — used inside Docker containers (web / worker containers connect to db service)
# DATABASE_URL=postgresql://eanhl:changeme@db:5432/eanhl

# PostgreSQL password used by Docker Compose to initialise the db container.
# Must match the password in DATABASE_URL above.
POSTGRES_PASSWORD=changeme

# EA Pro Clubs API — do not change these for club #19224
EA_CLUB_ID=19224
EA_PLATFORM=common-gen5

# Worker tuning (milliseconds) — defaults shown
POLL_INTERVAL_MS=300000
EA_REQUEST_DELAY_MS=1000
INGEST_CYCLE_TIMEOUT_MS=120000

{
  "name": "@eanhl/worker",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "node --watch dist/index.js",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "test": "pnpm run build && node --test dist/**/*.test.js",
    "reprocess": "node dist/reprocess.js",
    "ingest-now": "node dist/ingest-now.js",
    "ingest-ocr": "node dist/ingest-ocr-cli.js",
    "ingest-ocr-resolve": "node dist/ingest-ocr-resolve-cli.js",
    "ingest-ocr-review": "node dist/ingest-ocr-review-cli.js"
  },
  "dependencies": {
    "@eanhl/db": "workspace:*",
    "@eanhl/ea-client": "workspace:*",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  }
}
